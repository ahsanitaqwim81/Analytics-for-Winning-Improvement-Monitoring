{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Buka index.html Langsung (Tanpa Server)",
            "type": "chrome",
            "request": "launch",
            "file": "${workspaceFolder}/index.html",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Buka via Live Preview (localhost:3000)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000/index.html",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Buka via Live Server (localhost:5500)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5500/index.html",
            "webRoot": "${workspaceFolder}"
        }
    ]
}